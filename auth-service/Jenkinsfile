pipeline {
    agent any

    environment {
        // Set your microservice name here: 'auth-service', 'product-service', or 'order-service'
        SERVICE_NAME     = 'auth-service'
        DOCKER_USERNAME  = 'avinash8476'
        IMAGE_TAG        = "${BUILD_NUMBER}"
        DOCKER_IMAGE     = "${DOCKER_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG}"
    }

    stages {
        stage('Clone Repository') {
            steps {
                echo "📥 Cloning repository branch 'main'..."
                git(
                    branch: 'main',
                    credentialsId: 'ecmp-apps-uat',
                    url: 'https://github.com/avinash2354/ecmp-apps-uat.git'
                )
            }
        }

        stage('Build Docker Image') {
    steps {
        echo "🔨 Building Docker image for ${SERVICE_NAME}..."
        // Build the Docker image using dynamic variables
        sh "docker build -t ${DOCKER_IMAGE} ./${SERVICE_NAME}"
    }
}

stage('Push to Docker Hub') {
    steps {
        withCredentials([usernamePassword(
            credentialsId: 'dockerhub-pass',
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
        )]) {
            echo "🔐 Logging in to Docker Hub..."
            sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
            echo "🚀 Pushing Docker image ${DOCKER_IMAGE}..."
            sh "docker push ${DOCKER_IMAGE}"
        }
    }
}

    }
}
